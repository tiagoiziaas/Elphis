// Prisma schema for Elpis - Health Tech Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User model - base authentication
model User {
  id                  String              @id @default(cuid())
  name                String
  email               String              @unique
  passwordHash        String              @map("password_hash")
  role                String              @default("PATIENT")
  // MFA
  mfaEnabled          Boolean             @default(false) @map("mfa_enabled")
  mfaSecretEnc        String?             @map("mfa_secret_enc")
  mfaRecoveryCodes    String?             @map("mfa_recovery_codes")
  // Account lockout
  failedAttempts      Int                 @default(0) @map("failed_attempts")
  lockedUntil         DateTime?           @map("locked_until")
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  professionalProfile ProfessionalProfile?
  appointments        Appointment[]       @relation("PatientAppointments")
  auditLogs           AuditLog[]

  @@map("users")
}



// Professional Profile - public facing profile for health professionals
model ProfessionalProfile {
  id                String             @id @default(cuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug              String             @unique
  fullName          String             @map("full_name")
  title             String             @default("Especialista")
  specialty         String
  city              String
  state             String
  bio               String?
  approach          String?            @map("approach")
  headline          String?            @map("headline")
  profileImageUrl   String?            @map("profile_image_url")
  coverImageUrl     String?            @map("cover_image_url")
  whatsapp          String?
  instagram         String?
  website           String?
  isPublic          Boolean            @default(true) @map("is_public")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  services          ProfessionalService[]
  contentPosts      ContentPost[]
  availabilityRules AvailabilityRule[]
  appointments      Appointment[]
  patients          Patient[]
  anamneses         Anamnese[]
  anamneseTokens    AnamneseToken[]
  customTemplates   CustomAnamneseTemplate[]
  categoryId                String?            @map("category_id")
  category                  Category?          @relation(fields: [categoryId], references: [id])
  businessCard              BusinessCard?
  defaultConsultationType   String?            @map("default_consultation_type")
  defaultConsultationValue  Float?           @map("default_consultation_value") 
  councilType               String?            @map("council_type")   // Ex: CRM, CRN, CREFITO, CRP, CFP
  councilNumber             String?            @map("council_number") // Ex: 12345-SP

  @@index([slug])
  @@index([specialty])
  @@index([city, state])
  @@index([isPublic])
  @@map("professional_profiles")
}

// Professional Services offered
model ProfessionalService {
  id                String             @id @default(cuid())
  professionalProfileId String         @map("professional_profile_id")
  professionalProfile ProfessionalProfile @relation(fields: [professionalProfileId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  price             Float?           
  duration          Int?               // duration in minutes
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  appointments      Appointment[]

  @@index([professionalProfileId])
  @@map("professional_services")
}

// Content Posts - articles and videos published by professionals
model ContentPost {
  id                String             @id @default(cuid())
  professionalProfileId String         @map("professional_profile_id")
  professionalProfile ProfessionalProfile @relation(fields: [professionalProfileId], references: [id], onDelete: Cascade)
  title             String
  slug              String             @unique
  excerpt           String?
  content           String             
  coverImageUrl     String?            @map("cover_image_url")
  videoUrl          String?            @map("video_url")
  attachmentUrl     String?            @map("attachment_url")
  type              String        @default("ARTICLE")
  status            String      @default("DRAFT")
  publishedAt       DateTime?          @map("published_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  @@index([slug])
  @@index([professionalProfileId])
  @@index([status])
  @@index([type])
  @@map("content_posts")
}





// Availability Rules - weekly schedule for professionals
model AvailabilityRule {
  id                String             @id @default(cuid())
  professionalProfileId String         @map("professional_profile_id")
  professionalProfile ProfessionalProfile @relation(fields: [professionalProfileId], references: [id], onDelete: Cascade)
  weekDay           Int                @map("week_day") // 0-6 (Sunday-Saturday)
  startTime         String             @map("start_time") // HH:mm format
  endTime           String             @map("end_time") // HH:mm format
  active            Boolean            @default(true)
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  @@index([professionalProfileId])
  @@map("availability_rules")
}

// Appointments - booking system
model Appointment {
  id                String             @id @default(cuid())
  professionalProfileId String         @map("professional_profile_id")
  professionalProfile ProfessionalProfile @relation(fields: [professionalProfileId], references: [id], onDelete: Cascade)
  patientId         String?            @map("patient_id")
  patient           User?              @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: SetNull)
  patientRecordId   String?            @map("patient_record_id") // Reference to Patient model
  patientRecord     Patient?           @relation(fields: [patientRecordId], references: [id], onDelete: SetNull)
  patientName       String             @map("patient_name")
  patientEmail      String             @map("patient_email")
  patientPhone      String             @map("patient_phone")
  serviceId         String?            @map("service_id")
  service           ProfessionalService? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  scheduledDate     DateTime           @map("scheduled_date")
  scheduledTime     String             @map("scheduled_time") // HH:mm format - start time
  scheduledEndTime  String?            @map("scheduled_end_time") // HH:mm format - end time
  status            String  @default("PENDING")
  notes             String?            
  
  // Consultation details
  consultationValue Float?           @map("consultation_value") 
  attendanceType    String     @default("IN_PERSON") @map("attendance_type") // ONLINE or IN_PERSON
  
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  @@index([professionalProfileId])
  @@index([patientId])
  @@index([patientRecordId])
  @@index([scheduledDate])
  @@index([status])
  @@map("appointments")
}





// Categories - for organizing professionals by specialty
model Category {
  id                String             @id @default(cuid())
  name              String             @unique
  slug              String             @unique
  description       String?
  icon              String?
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  professionalProfiles ProfessionalProfile[]

  @@index([slug])
  @@map("categories")
}

// Business Card - digital business card for professionals
model BusinessCard {
  id                String             @id @default(cuid())
  professionalProfileId String         @unique @map("professional_profile_id")
  professionalProfile ProfessionalProfile @relation(fields: [professionalProfileId], references: [id], onDelete: Cascade)

  // Contact information
  phone             String?
  email             String?
  website           String?

  // Social media
  instagram         String?
  facebook          String?
  linkedin          String?
  youtube           String?
  tiktok            String?

  // Address
  address           String?
  addressNumber     String?            @map("address_number")
  addressComplement String?            @map("address_complement")
  neighborhood      String?
  city              String?
  state             String?
  zipCode           String?            @map("zip_code")

  // Additional info
  description       String?
  services          String?           // Array of service names

  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  @@index([professionalProfileId])
  @@map("business_cards")
}

// Patient - patient records managed by professionals
model Patient {
  id                String             @id @default(cuid())
  professionalProfileId String         @map("professional_profile_id")
  professionalProfile ProfessionalProfile @relation(fields: [professionalProfileId], references: [id], onDelete: Cascade)
  
  // Personal Information
  firstName         String             @map("first_name")
  lastName          String             @map("last_name")
  email             String?
  phone             String?
  whatsapp          String?
  dateOfBirth       DateTime?          @map("date_of_birth")
  gender            String?            // Male, Female, Other, Prefer not to say
  age               Int?               // Calculated or manually entered
  
  // Address
  address           String?
  addressNumber     String?            @map("address_number")
  addressComplement String?            @map("address_complement")
  neighborhood      String?
  city              String?
  state             String?
  zipCode           String?            @map("zip_code")
  
  // Health Information (optional)
  chiefComplaint    String?            @map("chief_complaint") // Queixa principal
  medicalHistory    String?            @map("medical_history") // Histórico resumido
  notes             String?            
  
  // Default Consultation Settings
  defaultConsultationType   String?    @map("default_consultation_type")
  defaultConsultationValue  Float?   @map("default_consultation_value") 
  
  // Profile photo
  profileImageUrl   String?            @map("profile_image_url")
  
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  
  appointments      Appointment[]
  anamneses         Anamnese[]
  customSubmissions CustomAnamneseSubmission[]
  customTokens      CustomAnamneseToken[]

  @@index([professionalProfileId])
  @@index([email])
  @@index([phone])
  @@map("patients")
}

// AnamneseToken - token for patient to fill anamnesis via link
model AnamneseToken {
  id                    String              @id @default(cuid())
  token                 String              @unique
  professionalProfileId String              @map("professional_profile_id")
  professionalProfile   ProfessionalProfile @relation(fields: [professionalProfileId], references: [id], onDelete: Cascade)
  patientName           String?             @map("patient_name") // optional pre-fill
  expiresAt             DateTime            @map("expires_at")
  usedAt                DateTime?           @map("used_at")
  createdAt             DateTime            @default(now()) @map("created_at")
  anamnese              Anamnese?

  @@index([token])
  @@index([professionalProfileId])
  @@map("anamnese_tokens")
}

// Anamnese - Anamnese Infantil de Psicologia
model Anamnese {
  id                    String              @id @default(cuid())
  professionalProfileId String              @map("professional_profile_id")
  professionalProfile   ProfessionalProfile @relation(fields: [professionalProfileId], references: [id], onDelete: Cascade)
  patientId             String?             @map("patient_id")
  patient               Patient?            @relation(fields: [patientId], references: [id], onDelete: SetNull)
  tokenId               String?             @unique @map("token_id")
  anamneseToken         AnamneseToken?      @relation(fields: [tokenId], references: [id], onDelete: SetNull)
  preenchidoPor         String              @default("profissional") @map("preenchido_por") // "profissional" | "paciente"

  // Identificação do paciente
  nomeCompleto          String?             @map("nome_completo")
  dataNascimento        String?             @map("data_nascimento")
  idade                 String?
  sexo                  String?
  escolaridade          String?
  endereco              String?
  cidade                String?

  // Responsáveis
  nomePai               String?             @map("nome_pai")
  idadePai              String?             @map("idade_pai")
  estadoCivilPai        String?             @map("estado_civil_pai")
  rgPai                 String?             @map("rg_pai")
  cpfPai                String?             @map("cpf_pai")
  escolaridadePai       String?             @map("escolaridade_pai")
  profissaoPai          String?             @map("profissao_pai")
  telefonePai           String?             @map("telefone_pai")
  nomeMae               String?             @map("nome_mae")
  idadeMae              String?             @map("idade_mae")
  estadoCivilMae        String?             @map("estado_civil_mae")
  rgMae                 String?             @map("rg_mae")
  cpfMae                String?             @map("cpf_mae")
  escolaridadeMae       String?             @map("escolaridade_mae")
  profissaoMae          String?             @map("profissao_mae")
  telefoneMae           String?             @map("telefone_mae")
  encaminhadoPor        String?             @map("encaminhado_por")

  // Queixa principal
  queixa                String?             @db.Text
  resideCom             String?             @map("reside_com") @db.Text
  irmaos                String?             @db.Text
  adotado               String?

  // Gestação
  gestacaoPlanejada     String?             @map("gestacao_planejada")
  gestacaoDesejada      String?             @map("gestacao_desejada")
  prenatal              String?
  intercorrencias       String?             @db.Text
  consumoSubstancias    String?             @map("consumo_substancias") @db.Text
  transfusao            String?
  tombo                 String?             @db.Text
  condicoeNascimento    String?             @map("condicoe_nascimento") @db.Text

  // Saúde
  acidentes             String?             @db.Text
  alergias              String?
  bronquiteAsma         String?             @map("bronquite_asma")
  visao                 String?
  audicao               String?
  dorcabeca             String?
  desmaios              String?
  convulsoes            String?
  historiaFamiliar      String?             @map("historia_familiar")
  obsSaude              String?             @map("obs_saude") @db.Text

  // Alimentação
  amamentacao           String?
  alimentacao           String?             @db.Text
  forcadaAlimentar      String?             @map("forcada_alimentar")
  comeSemDerrubar       String?             @map("come_sem_derrubar")
  ajudaAlimentacao      String?             @map("ajuda_alimentacao")
  obsAlimentacao        String?             @map("obs_alimentacao") @db.Text

  // Sono
  dormeBem              String?             @map("dorme_bem")
  qualidadeSono         String?             @map("qualidade_sono")
  falaDormindo          String?             @map("fala_dormindo")
  sonambulo             String?
  rangeDentes           String?             @map("range_dentes")
  quartoSeparado        String?             @map("quarto_separado")
  comQuemDorme          String?             @map("com_quem_dorme")
  acordaCamaPais        String?             @map("acorda_cama_pais")
  obsSono               String?             @map("obs_sono") @db.Text

  // Desenvolvimento psicomotor
  comoBebe              String?             @map("como_bebe")
  lentoTarefas          String?             @map("lento_tarefas")
  vesteSozinho          String?             @map("veste_sozinho")
  banhaSozinho          String?             @map("banha_sozinho")
  calcaSozinho          String?             @map("calca_sozinho")
  noCalcados            String?             @map("no_calcados")
  desastrado            String?
  esportes              String?
  roiUnhas              String?             @map("roi_unhas")
  chupaDedo             String?             @map("chupa_dedo")
  manias                String?
  ajudaTarefas          String?             @map("ajuda_tarefas")
  obsMotor              String?             @map("obs_motor") @db.Text

  // Escolaridade
  gostaEscola           String?             @map("gosta_escola")
  aceitoPelosAmigos     String?             @map("aceito_pelos_amigos")
  repetiu               String?
  motivoRepetiu         String?             @map("motivo_repetiu")
  gostaEstudar          String?             @map("gosta_estudar")
  habitoLeitura         String?             @map("habito_leitura")
  fazLicoes             String?             @map("faz_licoes")
  paisEstudam           String?             @map("pais_estudam")
  mudouEscola           String?             @map("mudou_escola")
  motivoMudou           String?             @map("motivo_mudou")
  matematica            String?
  dificuldadeLeitura    String?             @map("dificuldade_leitura")
  irrequieta            String?
  circunstancias        String?
  dificuldadesEscola    String?             @map("dificuldades_escola") @db.Text
  professoresAcham      String?             @map("professores_acham")
  obsEscola             String?             @map("obs_escola") @db.Text

  // Linguagem
  comunicacaoAtual      String?             @map("comunicacao_atual") @db.Text
  obsLinguagem          String?             @map("obs_linguagem") @db.Text

  // Sexualidade
  educacaoSexual        String?             @map("educacao_sexual")
  dequemEducacaoSexual  String?             @map("dequem_educacao_sexual")
  comoFoiSexual         String?             @map("como_foi_sexual")
  curiosidadeSexual     String?             @map("curiosidade_sexual")
  paisConversam         String?             @map("pais_conversam")
  obsSexualidade        String?             @map("obs_sexualidade") @db.Text

  // Aspectos ambientais
  brincaSozinha         String?             @map("brinca_sozinha")
  brincaComIdade        String?             @map("brinca_com_idade")
  fazAmigos             String?             @map("faz_amigos")
  adaptaMeio            String?             @map("adapta_meio")
  relacaoPais           String?             @map("relacao_pais")
  relacaoIrmaos         String?             @map("relacao_irmaos")
  medidasDisciplinares  String?             @map("medidas_disciplinares") @db.Text
  quemUsa               String?             @map("quem_usa")
  reacoesMedidas        String?             @map("reacoes_medidas")
  obsAmbiental          String?             @map("obs_ambiental") @db.Text

  // Características pessoais e afetivo-emocionais
  aspectoEmocional      String?             @map("aspecto_emocional") @db.Text
  caracteristicas       String?             @db.Text // JSON array of selected traits
  outrasCaracteristicas String?             @map("outras_caracteristicas")
  reageContrariedade    String?             @map("reage_contrariedade")
  atividadesPreferidas  String?             @map("atividades_preferidas")
  obsEmocional          String?             @map("obs_emocional") @db.Text

  // Rotina diária
  rotinaDiaria          String?             @map("rotina_diaria") @db.Text

  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  @@index([professionalProfileId])
  @@index([patientId])
  @@map("anamneses")
}

// Audit Log - append-only, encrypted, HMAC-protected
model AuditLog {
  id           String   @id @default(cuid())
  eventTime    DateTime @default(now()) @map("event_time")
  userId       String?  @map("user_id")
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  eventType    String   @map("event_type")
  tableName    String?  @map("table_name")
  recordId     String?  @map("record_id")
  ipAddress    String?  @map("ip_address")
  payloadEnc   String   @map("payload_enc")    // AES-256-GCM encrypted JSON
  integrityMac String   @map("integrity_mac")  // HMAC-SHA256 of payloadEnc

  @@index([userId])
  @@index([eventType])
  @@index([eventTime])
  @@map("audit_logs")
}

model CustomAnamneseTemplate {
  id                    String                    @id @default(cuid())
  professionalProfileId String                    @map("professional_profile_id")
  professionalProfile   ProfessionalProfile       @relation(fields: [professionalProfileId], references: [id], onDelete: Cascade)
  title                 String
  questionsJson         String                    @db.Text
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @updatedAt @map("updated_at")
  submissions           CustomAnamneseSubmission[]
  tokens                CustomAnamneseToken[]

  @@index([professionalProfileId])
  @@map("custom_anamnese_templates")
}

model CustomAnamneseSubmission {
  id                    String                    @id @default(cuid())
  templateId            String                    @map("template_id")
  template              CustomAnamneseTemplate    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  professionalProfileId String                    @map("professional_profile_id")
  patientId             String?                   @map("patient_id")
  patient               Patient?                  @relation(fields: [patientId], references: [id], onDelete: SetNull)
  nomeCompleto          String?                   @map("nome_completo")
  answersJson           String                    @db.Text
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @updatedAt @map("updated_at")

  @@index([templateId])
  @@index([professionalProfileId])
  @@index([patientId])
  @@map("custom_anamnese_submissions")
}

model CustomAnamneseToken {
  id                    String                    @id @default(cuid())
  token                 String                    @unique
  templateId            String                    @map("template_id")
  template              CustomAnamneseTemplate    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  professionalProfileId String                    @map("professional_profile_id")
  patientId             String?                   @map("patient_id")
  patient               Patient?                  @relation(fields: [patientId], references: [id], onDelete: SetNull)
  expiresAt             DateTime                  @map("expires_at")
  usedAt                DateTime?                 @map("used_at")
  createdAt             DateTime                  @default(now()) @map("created_at")

  @@index([token])
  @@index([templateId])
  @@index([professionalProfileId])
  @@index([patientId])
  @@map("custom_anamnese_tokens")
}
