# Supabase Configuration
# URL do projeto
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co

# Chaves do Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database Connection (Supabase - conexão direta)
DATABASE_URL=postgresql://postgres:your-db-password@db.your-supabase-project.supabase.co:5432/postgres?sslmode=require
DIRECT_URL=postgresql://postgres:your-db-password@db.your-supabase-project.supabase.co:5432/postgres?sslmode=require

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-next-auth-secret-key-change-in-production

# Criptografia de campos sensíveis (AES-256-GCM)
# Gere com: openssl rand -hex 32
ENCRYPTION_KEY=your-64-char-hex-key-here

# HMAC para integridade dos Audit Logs (SEPARADO do ENCRYPTION_KEY)
# Gere com: openssl rand -hex 32
AUDIT_HMAC_SECRET=your-64-char-hex-hmac-secret-here

# Nome do app exibido no Google Authenticator / Authy
MFA_ISSUER=Elphis

